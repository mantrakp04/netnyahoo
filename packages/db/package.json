{
  "name": "@netnyahoo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:delete": "node ./scripts/delete-db.mjs",
