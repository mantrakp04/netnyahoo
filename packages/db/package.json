    "db:push": "node --no-warnings ./scripts/push-db.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@netnyahoo/config": "workspace:*",
    "@netnyahoo/env": "workspace:*",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10"
  }
}
